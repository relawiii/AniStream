{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "types": ["node"],
    "paths": {
      "@workspace/db": ["../lib/db/src/index.ts"],
      "@workspace/db/schema": ["../lib/db/src/schema/index.ts"]
    }
  },
  "include": ["**/*.ts", "../lib/db/src/**/*.ts"]
}
